{
  "name": "neraium-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3010",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 3010",
    "lint": "npm exec eslint -- src --ext .jsx,.js",
    "lint:ci": "npm exec eslint -- src --ext .jsx,.js --max-warnings=0",
    "test": "vitest --environment jsdom",
    "test:e2e": "playwright test",
    "setup:codex": "npm ci && npx playwright install --with-deps chromium",
    "verify": "npm run lint:ci && npm run build && npm run perf:budget && npm test -- --run",
    "perf:budget": "node scripts/check-performance-budgets.cjs"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.41.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "^8.55.0",
    "eslint-config-react-app": "^7.0.1",
    "jsdom": "^29.1.1",
    "vite": "^8.0.16",
    "vitest": "4.1.7"
  }
}
