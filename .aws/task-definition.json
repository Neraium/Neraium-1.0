{
    "family": "default-sha256-acf9",
    "networkMode":  "awsvpc",
    "requiresCompatibilities":  [
                                    "FARGATE"
                                ],
    "cpu":  "512",
    "memory":  "1024",
    "containerDefinitions":  [
                                 {
                                     "name": "Main",
                                     "image":  "PLACEHOLDER",
                                     "essential":  true,
                                     "environment":  [
                                                         {
                                                             "name":  "APP_ENV",
                                                             "value":  "production"
                                                         },
                                                         {
                                                             "name":  "BACKEND_HOST",
                                                             "value":  "0.0.0.0"
                                                         },
                                                         {
                                                             "name":  "BACKEND_PORT",
                                                             "value":  "8080"
                                                         },
                                                         {
                                                             "name":  "CORS_ORIGINS",
                                                             "value":  "https://app.neraium.com,https://www.app.neraium.com"
                                                         },
                                                         {
                                                             "name":  "CORS_ORIGIN_REGEX",
                                                             "value":  "^https://([a-z0-9-]+\\.)?neraium\\.com$"
                                                         },
                                                         {
                                                             "name":  "NERAIUM_RUNTIME_DIR",
                                                             "value":  "/mnt/neraium-runtime"
                                                         }
                                                     ],
                                     "portMappings":  [
                                                          {
                                                              "containerPort":  8080,
                                                              "hostPort":  8080,
                                                              "protocol":  "tcp"
                                                          }
                                                      ],
                                     "healthCheck":  {
                                                         "command":  [
                                                                          "CMD-SHELL",
                                                                          "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8080/api/health', timeout=5).read()\" || exit 1"
                                                                      ],
                                                         "interval":  30,
                                                         "timeout":  10,
                                                         "retries":  3,
                                                         "startPeriod":  10
                                                     }
                                 }
                             ],
    "executionRoleArn":  "arn:aws:iam::680779862188:role/service-role/ecsTaskExecutionRole"
}

