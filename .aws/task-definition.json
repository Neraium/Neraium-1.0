{
    "family":  "neraium-api",
    "networkMode":  "awsvpc",
    "requiresCompatibilities":  [
                                    "FARGATE"
                                ],
    "cpu":  "512",
    "memory":  "1024",
    "containerDefinitions":  [
                                 {
                                     "name":  "neraium-api",
                                     "image":  "PLACEHOLDER",
                                     "essential":  true,
                                     "portMappings":  [
                                                          {
                                                              "containerPort":  8000,
                                                              "hostPort":  8000,
                                                              "protocol":  "tcp"
                                                          }
                                                      ]
                                 }
                             ],
    "executionRoleArn":  null
}
