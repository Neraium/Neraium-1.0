{
    "family": "default-sha256-acf9",
    "networkMode":  "awsvpc",
    "requiresCompatibilities":  [
                                    "FARGATE"
                                ],
    "cpu":  "512",
    "memory":  "1024",
    "containerDefinitions":  [
                                 {
                                     "name": "Main",
                                     "image":  "PLACEHOLDER",
                                     "essential":  true,
                                     "environment":  [
                                                         {
                                                             "name":  "APP_ENV",
                                                             "value":  "production"
                                                         },
                                                         {
                                                             "name":  "BACKEND_HOST",
                                                             "value":  "0.0.0.0"
                                                         },
                                                         {
                                                             "name":  "BACKEND_PORT",
                                                             "value":  "80"
                                                         },
                                                         {
                                                             "name":  "CORS_ORIGINS",
                                                             "value":  "https://app.neraium.com,https://www.app.neraium.com"
                                                         },
                                                         {
                                                             "name":  "CORS_ORIGIN_REGEX",
                                                             "value":  "^https://([a-z0-9-]+\\.)?neraium\\.com$"
                                                         },
                                                         {
                                                             "name":  "NERAIUM_RUNTIME_DIR",
                                                             "value":  "/tmp/neraium-runtime"
                                                         }
                                                     ],
                                     "portMappings":  [
                                                          {
                                                              "containerPort":  80,
                                                              "hostPort":  80,
                                                              "protocol":  "tcp"
                                                          }
                                                      ]
                                 }
                             ],
    "executionRoleArn":  "arn:aws:iam::680779862188:role/service-role/ecsTaskExecutionRole"
}

