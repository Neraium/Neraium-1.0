# Application runtime
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8010
CORS_ORIGINS=http://127.0.0.1:3010,http://localhost:3010,https://app.neraium.com
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?neraium\.com$
NERAIUM_RUNTIME_DIR=backend/app/runtime
NERAIUM_PROCESS_ROLE=all
NERAIUM_START_BACKGROUND_WORKERS=true
NERAIUM_START_DATA_POLLER=false
NERAIUM_SHUTDOWN_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Upload and retention controls
NERAIUM_MAX_UPLOAD_SIZE_BYTES=10737418240
NERAIUM_MAX_PENDING_UPLOAD_JOBS=50
NERAIUM_CSV_CHUNK_SIZE_ROWS=5000
NERAIUM_CSV_PROGRESS_UPDATE_EVERY=5000
NERAIUM_MAX_INGESTION_ANALYSIS_ROWS=100000
NERAIUM_UPLOAD_QUEUE_RETENTION_DAYS=14
NERAIUM_EVIDENCE_RUN_RETENTION_DAYS=45
NERAIUM_SII_MAX_VECTOR_ROWS=4096
NERAIUM_SII_RECENT_VECTOR_TAIL=512
NERAIUM_INLINE_REPLAY_GENERATION=false

# Split-role/shared state (required for production api + worker deployments)
NERAIUM_UPLOAD_STATE_BUCKET=
NERAIUM_UPLOAD_STATE_PREFIX=upload-state/

# Optional external telemetry
NERAIUM_DEFAULT_TELEMETRY_URL=

# Optional alert delivery. Store passwords and webhook URLs in a secret manager.
NERAIUM_NOTIFICATION_WEBHOOK_URL=
NERAIUM_NOTIFICATION_EMAIL_RECIPIENTS=
NERAIUM_SMTP_HOST=
NERAIUM_SMTP_PORT=587
NERAIUM_SMTP_USERNAME=
NERAIUM_SMTP_PASSWORD=
NERAIUM_SMTP_SENDER=
NERAIUM_SMTP_USE_TLS=true

# Service authentication and bootstrap secrets. Never commit real values.
NERAIUM_API_TOKEN=
NERAIUM_API_TOKEN_ROLE=admin
# Required for production API/monolith roles; inject a PostgreSQL DSN from a secret manager.
NERAIUM_AUTH_DATABASE_URL=
NERAIUM_BOOTSTRAP_ADMIN_EMAIL=
NERAIUM_BOOTSTRAP_ADMIN_PASSWORD=
NERAIUM_BOOTSTRAP_ADMIN_NAME=Admin
