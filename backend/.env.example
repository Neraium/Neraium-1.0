APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8010
CORS_ORIGINS=https://app.neraium.com
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\\.)?neraium\\.com$

# Security-sensitive values must be injected by the runtime secret manager.
NERAIUM_API_TOKEN=
NERAIUM_API_TOKEN_ROLE=admin
NERAIUM_BOOTSTRAP_ADMIN_EMAIL=
NERAIUM_BOOTSTRAP_ADMIN_PASSWORD=
NERAIUM_AUTH_DATABASE_URL=
NERAIUM_MAX_UPLOAD_SIZE_BYTES=262144000
