BACKEND_HOST=127.0.0.1
BACKEND_PORT=8010
CORS_ORIGINS=http://127.0.0.1:3010,http://localhost:3010,https://app.neraium.com
NERAIUM_RUNTIME_DIR=backend/app/runtime
NERAIUM_UPLOAD_CHUNK_SIZE_ROWS=10000
NERAIUM_MAX_ANALYSIS_ROWS=20000
NERAIUM_MAX_SII_ROWS=5000

FRONTEND_PORT=3010
VITE_API_BASE_URL=http://127.0.0.1:8010

APP_ENV=development

# Security-sensitive values must be injected by the runtime secret manager.
NERAIUM_API_TOKEN=
NERAIUM_API_TOKEN_ROLE=admin
NERAIUM_BOOTSTRAP_ADMIN_EMAIL=
NERAIUM_BOOTSTRAP_ADMIN_PASSWORD=
NERAIUM_AUTH_DATABASE_URL=
NERAIUM_MAX_UPLOAD_SIZE_BYTES=262144000
